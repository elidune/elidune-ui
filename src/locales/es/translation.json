    "dataCollected": {
      "title": "Datos recopilados",
      "description": "En el marco del uso del software de gestión de bibliotecas Elidune, se recopilan los siguientes datos personales:",
      "items": "Apellido, nombre, nombre de usuario, dirección de correo electrónico, tipo de cuenta (miembro, bibliotecario, administrador), historial de préstamos y devoluciones, actividad en el sistema (registro de auditoría)."
    },
    "purpose": {
      "title": "Finalidades del tratamiento",
      "description": "Los datos se tratan con las siguientes finalidades:",
      "items": "Gestión de cuentas de usuario y autenticación, seguimiento de préstamos y devoluciones, administración de la biblioteca, estadísticas de uso anonimizadas, envío de recordatorios para préstamos vencidos."
    },
    "legalBasis": {
      "title": "Base jurídica",
      "description": "El tratamiento se basa en el cumplimiento de una misión de interés público o en el ejercicio de poderes públicos (artículo 6.1.e del RGPD), así como en el contrato entre el usuario y la biblioteca (artículo 6.1.b)."
    },
