    "title": "Política de privacidad",
    "subtitle": "Información sobre el tratamiento de datos personales (RGPD)",
    "lastUpdate": "Última actualización",
    "dataController": {
      "title": "Responsable del tratamiento",
      "description": "El responsable del tratamiento de los datos recopilados a través de este software es:"
